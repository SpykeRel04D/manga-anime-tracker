# Local development (Docker PostgreSQL)
LOCAL_DATABASE_URL=postgresql://manga_tracker:manga_tracker@localhost:5433/manga_tracker

# Local auth URL
BETTER_AUTH_URL=http://localhost:3000

# Optional in local development, required in production
BETTER_AUTH_SECRET=

# Registration policy
ALLOW_REGISTRATION=false

# Production (Neon PostgreSQL) -- set in Vercel dashboard
# NEON_DATABASE_URL=postgresql://...

# Node environment
NODE_ENV=development
